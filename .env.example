NODE_ENV=development
PORT=5000
API_URL=http://localhost:5000
WEB_URL=http://localhost:5173
ALLOW_SEED=false

MONGO_URI=mongodb+srv://USERNAME:PASSWORD@HOST/DATABASE_NAME?retryWrites=true&w=majority
JWT_ACCESS_SECRET=replace_me_access_secret_at_least_24_chars
JWT_REFRESH_SECRET=replace_me_refresh_secret_at_least_24_chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

CLOUDINARY_CLOUD_NAME=replace_me
CLOUDINARY_API_KEY=replace_me
CLOUDINARY_API_SECRET=replace_me
IMAGE_WEBP_THRESHOLD_KB=250
IMAGE_WEBP_QUALITY=82
MAX_IMAGE_SIZE_MB=8
